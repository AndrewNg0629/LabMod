{
	"schemaVersion": 1,
	"id": "labmod",
	"version": "${version}",
	"name": "LabMod",
	"description": "A lab for Minecraft mod development.",
	"authors": [
		"AndrewNg0629"
	],
	"contact": {
		"sources": "https://github.com/AndrewNg0629/LabMod"
	},
	"license": "MIT",
	"icon": "assets/labmod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"online.andrew2007.labmod.LabMod"
		],
		"client": [
			"online.andrew2007.labmod.LabModClient"
		]
	},
	"mixins": [
		"labmod.mixins.json",
		{
			"config": "labmod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.10",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	},
	"custom": {
		"modmenu": {
			"links": {
			},
			"badges": [],
			"update_checker": false
		},
		"loom:injected_interfaces": {
			"net/minecraft/class_635": [
				"online/andrew2007/labmod/network/v2/prototype/ClientLoginNetworkHandlerInjection"
			],
			"net/minecraft/class_3248": [
				"online/andrew2007/labmod/network/v2/prototype/ServerLoginNetworkHandlerInjection"
			]
		}
	}
}